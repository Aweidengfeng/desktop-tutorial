# SummitLink 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 必填 ────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# 数据库（Railway PostgreSQL 或自建）
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 安全密钥（请使用强随机字符串，≥32字符）
JWT_SECRET=your_jwt_secret_here_min_32_chars
ADMIN_PASSWORD=your_admin_password_here

# ===== 安全配置 =====
# 投资者看板访问 Token（生产环境建议配置；/investor 支持 ?token=xxx 或 Authorization: Bearer xxx，/api/investor/* 需使用 x-investor-token 请求头）
INVESTOR_TOKEN=
# CORS 白名单（生产环境必填，多个用逗号分隔）
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── 可选：地图 ───────────────────────────────────────
# 高德地图（国内/默认）— 需在 https://lbs.amap.com/ 申请
AMAP_KEY=
AMAP_SECURITY_CODE=
# 海外 Mapbox（未设置则全部用户使用高德）
MAPBOX_TOKEN=

# ── 可选：移动端深链与商店跳转 ────────────────────────
# Universal Links (iOS) / App Links (Android) 占位符会在 /.well-known/* 响应时被替换
# 多个 Android 签名指纹用逗号分隔
APPLE_TEAM_ID=
ANDROID_SHA256_FINGERPRINT=
# 未配置时使用占位 App Store / Play Store 链接（不会跳转到真实 App）
APP_STORE_URL=
PLAY_STORE_URL=

# ── 对象存储（腾讯云 COS）────────────────────────────
# 【生产环境必填 / Fail Closed】文件（图片/视频/文档/GPX）永久存储到腾讯云 COS。
# 生产环境（NODE_ENV=production）缺少以下任一配置将拒绝启动，且禁止回退本地磁盘。
# 开发/测试环境未配置时降级为本地磁盘存储。Bucket 建议带 APPID 后缀，如 unsummit-cn-1234567890
COS_BUCKET=
COS_REGION=ap-beijing
COS_SECRET_ID=
COS_SECRET_KEY=
COS_CDN_DOMAIN=
TENCENT_CLOUD_APPID=
TENCENT_CLOUD_REGION=ap-beijing
# 生产环境禁止设置 STORAGE_PROVIDER=local（会被启动校验拒绝）
# STORAGE_PROVIDER=

# ── 可选：海外对象存储（S3 / Cloudflare R2）───────────
S3_BUCKET_US=
S3_REGION_US=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── 可选：Sentry 错误监控 ────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_RATE=0.1

# ── 可选：上传目录（Docker 挂载卷时使用）────────────
UPLOADS_DIR=/app/uploads

# ── 可选：地域标识 ───────────────────────────────────
REGION=cn-hangzhou

# ── 可选：邮件通知（SMTP）────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SummitLink <noreply@summitlink.app>

# ── 可选：Resend 邮件服务（验证码 / 线索通知）──────────
# 未配置 RESEND_API_KEY 时邮件功能自动降级（仅日志，不阻塞业务）
RESEND_API_KEY=
RESEND_FROM=noreply@mail.ussummit.cn
# 官网线索（contact/partnerships/applications）通知收件人；
# 未设置则不发送通知邮件（提交仍正常写库）。也可用 ADMIN_EMAIL 兜底。
# 上线前请同时确认：
# - RESEND_API_KEY 和 RESEND_FROM 已配置，用于管理员通知和用户确认邮件
# - CORS_ORIGINS 包含 https://summitlink.cn 和实际 www/API 调用来源
# - 静态官网 website/js/config.js 的 SUMMITLINK_API_BASE 指向当前 API 域名
LEADS_NOTIFY_EMAIL=
ADMIN_EMAIL=

# ── 可选：Web Push 推送（VAPID）──────────────────────
# 生成密钥对: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@summitlink.app

# ── 可选：AI 教练 ─────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL_CLAUDE=claude-3-haiku-20240307
AI_MODEL_OPENAI=gpt-4o-mini

# ── 可选：Stripe 支付（国际支付）────────────────────────────
# 在 https://dashboard.stripe.com/apikeys 获取
# 测试模式密钥以 sk_test_ / pk_test_ 开头；生产密钥以 sk_live_ / pk_live_ 开头
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook 签名密钥：在 Stripe Dashboard → Webhooks → 端点详情中获取
# 用于验证 /api/payment/stripe-webhook 收到的事件真实性
STRIPE_WEBHOOK_SECRET=
# Stripe Connect（向导提现）：复用 STRIPE_SECRET_KEY，无需单独配置

# ── 保险公司 Webhook 验签密钥（接入保险公司时必填）──────────────
# 生成方式：openssl rand -hex 32
# 保险公司发来的每个 Webhook 请求头携带 X-Insurance-Signature: HMAC-SHA256(body, 此密钥)
INSURANCE_WEBHOOK_SECRET=

# ── 可选：Google / Apple 登录 ──────────────────────────────────
# Google OAuth 客户端 ID（在 Google Cloud Console 创建）
GOOGLE_CLIENT_ID=
# Apple Sign In（Service ID，在 Apple Developer → Certificates → Identifiers 获取）
# 后端已通过 APPLE_TEAM_ID 注入到前端 window.__APPLE_CLIENT_ID__
APPLE_CLIENT_ID=

# ── 可选：支付网关 ────────────────────────────────────
PAYMENT_PROVIDER=mock
PAYMENT_NOTIFY_URL=https://summitlink.app/api/payment/notify/wechat
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ── PII加密密钥 ───────────────────────────────────────────────────────────────
# 用于手机号、邮箱等敏感字段的AES-256-GCM加密
# 生成命令：openssl rand -hex 32
PII_ENCRYPTION_KEY=
