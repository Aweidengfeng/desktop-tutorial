# AlpineLink 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 必填 ────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# 数据库（Railway PostgreSQL 或自建）
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 安全密钥（请使用强随机字符串，≥32字符）
JWT_SECRET=your_jwt_secret_here_min_32_chars
ADMIN_PASSWORD=your_admin_password_here

# ── 可选：地图 ───────────────────────────────────────
# 高德地图（默认，无需配置）
# 海外 Mapbox（未设置则使用高德）
MAPBOX_TOKEN=

# ── 可选：阿里云 OSS 图片存储 ──────────────────────
# 未设置则使用本地磁盘存储
OSS_BUCKET=
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_CDN_HOST=

# ── 可选：阿里云内容安全（图片审核）──────────────────
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# ── 可选：Sentry 错误监控 ────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_RATE=0.1

# ── 可选：上传目录（Docker 挂载卷时使用）────────────
UPLOADS_DIR=/app/uploads

# ── 可选：地域标识 ───────────────────────────────────
REGION=cn-hangzhou

# ── 可选：邮件通知（SMTP）────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AlpineLink <noreply@alpinelink.com>

# ── 可选：Web Push 推送（VAPID）──────────────────────
# 生成密钥对: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@alpinelink.com
