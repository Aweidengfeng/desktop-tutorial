// ─────────────────────────────────────────
// 离线远征日志（新模块）
// ─────────────────────────────────────────

model UserExpeditionLog {
  id              Int       @id @default(autoincrement())
  clientUuid      String    @unique @map("client_uuid")
  userId          Int       @map("user_id")
  peakId          Int?      @map("peak_id")
  peakName        String?   @map("peak_name")
  status          String    @default("ongoing")
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  summited        Boolean   @default(false)
  maxAltitude     Float     @default(0) @map("max_altitude")
  totalGain       Float     @default(0) @map("total_gain")
  durationSec     Int       @default(0) @map("duration_sec")
  coverMediaUrl   String?   @map("cover_media_url")
  posterUrl       String?   @map("poster_url")
  totalMoments    Int       @default(0) @map("total_moments")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  peak        Peak?                  @relation(fields: [peakId], references: [id], onDelete: SetNull)
  moments     ExpeditionMoment[]
  subscribers ExpeditionSubscriber[]

  @@index([userId])
  @@map("user_expeditions_log")
}

model ExpeditionMoment {
  id            Int      @id @default(autoincrement())
  clientUuid    String   @unique @map("client_uuid")
  expeditionId  Int      @map("expedition_id")
  recordedAt    DateTime @map("recorded_at")
  altitude      Float    @default(0)
  lat           Float?
  lng           Float?
  type          String   @default("text")
  mediaUrl      String?  @map("media_url")
  content       String?
  createdAt     DateTime @default(now()) @map("created_at")

  expedition UserExpeditionLog @relation(fields: [expeditionId], references: [id], onDelete: Cascade)

  @@index([expeditionId])
  @@map("expedition_moments")
}

model ExpeditionSubscriber {
  id           Int      @id @default(autoincrement())
  expeditionId Int      @map("expedition_id")
  userId       Int      @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  expedition UserExpeditionLog @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expeditionId, userId])
  @@map("expedition_subscribers")
}

