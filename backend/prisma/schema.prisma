model Image {
  id         Int      @id @default(autoincrement())
  url        String
  filename   String
  size       Int?
  mimeType   String?  @map("mime_type")
  ownerType  String   @map("owner_type")
  ownerId    Int      @map("owner_id")
  fieldName  String?  @map("field_name")
  createdAt  DateTime @default(now()) @map("created_at")

