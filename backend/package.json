{
  "name": "summitlink-backend",
  "version": "1.0.0",
  "description": "巅峰探索 SummitLink 后端服务",
  "main": "app.js",
  "scripts": {
    "postinstall": "DATABASE_URL=\"file:/tmp/build.db\" node scripts/generate-prisma-client.js || true",
    "prestart": "node ../scripts/validate-env.js",
    "start": "node db/seed.js && node app.js",
    "dev": "node db/seed.js && node app.js",
    "seed": "node db/seed.js",
    "smoke": "node ../scripts/smoke-test.js",
    "check": "node ../scripts/pre-release-check.js",
    "test": "cd .. && npx jest --forceExit --no-coverage --runInBand --testPathPatterns=backend/tests/",
    "test:security": "cd .. && npx jest --forceExit --no-coverage --runInBand --testPathPatterns=backend/tests/security.test.js",
    "test:perf": "cd .. && npx jest --forceExit --no-coverage --runInBand --testTimeout=60000 --testPathPatterns=backend/tests/performance.test.js",
    "test:weak-network": "cd .. && npx jest --forceExit --no-coverage --runInBand --testPathPatterns=backend/tests/weak-network.test.js"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.5.1",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@sentry/node": "^8.0.0",
    "ali-oss": "^6.20.0",
    "openai": "^4.52.0",
    "web-push": "^3.6.0"
  }
}
