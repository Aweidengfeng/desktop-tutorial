JWT_SECRET=summitlink_secret_change_this_in_production
PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ── 服务对外 URL（Railway / 自定义域名）────────────────────────
# 必须填写！用于：
#   1. 管理后台 (/admin) 的同源 CORS 放行（否则登录时报"服务器内部错误"）
#   2. Capacitor 移动端 API 请求地址（前端 www/index.html 内硬编码使用）
# 示例：https://web-production-xxxx.up.railway.app 或 https://your-domain.com
API_BASE=https://your-railway-url.up.railway.app

# ── 短信服务（腾讯云 / 其他云短信）──────────────────────────
# 切换到真实云短信：将 SMS_PROVIDER 改为对应供应商，并填写以下变量
# 不设置（或设为 mock）时使用控制台打印模式，适合开发/内测
SMS_PROVIDER=mock
# 腾讯云短信应用 SDK AppID / 密钥（或替换为供应商对应变量）
TENCENT_SMS_APP_ID=your_tencent_sms_app_id
# 兼容旧变量名（可选）
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SECRET_ID=your_tencent_sms_secret_id
TENCENT_SMS_SECRET_KEY=your_tencent_sms_secret_key
# 短信签名 / 模板 ID（按供应商控制台创建）
TENCENT_SMS_SIGN_NAME=SummitLink
TENCENT_SMS_TEMPLATE_ID=1234567

# ── 邮件服务（SMTP）─────────────────────────────────────────
# 切换到 SMTP 发送：将 EMAIL_PROVIDER 改为 smtp，并填写以下变量
# 支持：腾讯企业邮箱、QQ 邮箱、163 邮箱、SendGrid 等
EMAIL_PROVIDER=mock
EMAIL_HOST=smtp.exmail.qq.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=noreply@your-domain.com
EMAIL_PASS=your_smtp_password_or_auth_code
EMAIL_FROM=SummitLink <noreply@your-domain.com>

# ── 微信登录 ────────────────────────────────────────────────
# 在微信开放平台（open.weixin.qq.com）创建移动应用，或在微信公众平台创建小程序后填写
# 填写后即自动启用真实微信 OAuth；不填则使用 mock 模式（开发测试专用）
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here
# 若使用微信小程序（而非移动应用），将下面设为 true
# 小程序模式使用 jscode2session 接口，无法获取用户昵称/头像（需前端调用 getUserProfile）
WECHAT_MINI_APP=false

# ── Apple 登录 ──────────────────────────────────────────────
# 在 Apple Developer（developer.apple.com）→ Certificates → Sign In with Apple 中获取
# 仅需填写 APPLE_CLIENT_ID（即 Services ID / Bundle ID），填写后即启用 JWKS 签名验证
# APPLE_CLIENT_ID 对应：
#   - iOS/macOS 原生 App：Bundle ID（如 com.example.summitlink）
#   - Web：Services ID（需在 Apple Developer 中单独创建）
APPLE_CLIENT_ID=com.example.summitlink
# 以下三个字段仅备查，服务器端 JWKS 验证不需要私钥（Apple 公钥从 Apple JWKS 端点获取）
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
# APPLE_PRIVATE_KEY 仅在需要生成 client_secret JWT（如 Web OAuth）时使用
# 对于原生 App（Capacitor Sign In with Apple），服务端只需 APPLE_CLIENT_ID
APPLE_PRIVATE_KEY=your_apple_private_key_here

# ── Google 登录 ─────────────────────────────────────────────
# 在 Google Cloud Console（console.cloud.google.com）→ API 和服务 → 凭据 中创建 OAuth 2.0 客户端 ID
# 填写后即启用真实 Google ID token 验证；不填则使用 mock 模式（开发测试专用）
# Web 客户端 ID（用于 Web 端 Google Identity Services / One Tap）
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ── 高德地图 ────────────────────────────────────────────────
# 在高德开放平台（lbs.amap.com）申请
AMAP_KEY=your_amap_key_here
# 高德 Web JS API 2.0 安全密钥（必须配置，否则地图无法加载）
AMAP_SECURITY_CODE=your_amap_security_code_here

# ── Mapbox 地图（海外用户 IP 自动切换）──────────────────────
# 在 https://account.mapbox.com/access-tokens/ 申请
# 仅对非 CN IP 用户生效（CN/未知 IP → 高德；其他 IP → Mapbox）
# 不填则海外用户也使用高德地图
MAPBOX_TOKEN=

# ── 移动端深链 & Universal Links / App Links ─────────────────
# 通过模板替换写入 /.well-known/apple-app-site-association 和 assetlinks.json
# Apple Developer Team ID（developer.apple.com → Membership → Team ID）
APPLE_TEAM_ID=
# Android 应用签名 SHA-256 指纹（多个用逗号分隔；通过 keytool -list -v 获取）
ANDROID_SHA256_FINGERPRINT=
# 应用商店链接（未配置则使用占位 ID，深链回退页将无法正确跳转）
APP_STORE_URL=
PLAY_STORE_URL=

# ── Stripe 支付（国际支付）──────────────────────────────────
# 在 https://dashboard.stripe.com/apikeys 获取
# 测试模式密钥以 sk_test_ / pk_test_ 开头；生产密钥以 sk_live_ / pk_live_ 开头
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook 签名密钥：在 Stripe Dashboard → Webhooks → 端点 → 签名密钥中获取
# 接收事件路径：POST /api/payment/stripe-webhook
STRIPE_WEBHOOK_SECRET=
# ── 保险公司 Webhook 验签密钥（接入保险公司时必填）──────────────
# 生成方式：openssl rand -hex 32
# 保险公司发来的每个 Webhook 请求头携带 X-Insurance-Signature: HMAC-SHA256(body, 此密钥)
INSURANCE_WEBHOOK_SECRET=
# Stripe 优雅降级开关
# 设为 true 时跳过 Stripe SDK 初始化，所有 /api/payment/* 返回 503
# 用于 Stripe Live 密钥尚未就绪时临时让生产恢复运行
# ⚠️ 一旦拿到 sk_live_ 密钥并配置好，必须将本变量删除（或设为 false）
STRIPE_DISABLED=

# ── 微信支付 v3（CN）──────────────────────────────────────────
# 以下变量任意缺失时自动进入 mock 模式，不抛出异常
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
# base64 编码 PEM（merchant private key）
WECHAT_PRIVATE_KEY=
# 可选：微信平台证书公钥（base64 PEM），用于回调验签
WECHAT_PLATFORM_PUBLIC_KEY=
# 分账开关：默认 false（mock）；真实商户开通后改为 true
WECHAT_SPLIT_ENABLED=false

# ── 支付宝（CN）────────────────────────────────────────────────
# 以下变量任意缺失时自动进入 mock 模式，不抛出异常
ALIPAY_APP_ID=
# base64 编码 PKCS8 私钥
ALIPAY_PRIVATE_KEY=
# base64 编码支付宝公钥
ALIPAY_PUBLIC_KEY=

# ── 数据持久化（Railway Volume 挂载）────────────────────────
# 将 Railway Volume 挂载到 /data，然后设置以下两个变量
DATABASE_PATH=/data/summitlink.db

# Prisma ORM 数据库连接
# 开发（SQLite）：
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"
# 生产（PostgreSQL）：
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:pass@host:5432/summitlink"
UPLOADS_DIR=/data/uploads

# ── CORS 白名单（生产环境必填，逗号分隔）────────────────────
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Seed 开关（首次部署设 true，之后改回 false）─────────────
SEED_ON_START=false

# ── FCM 推送（Android 原生推送）──────────────────────────────────────────
# 方式一：Firebase 服务账号完整 JSON（推荐）
# 在 Firebase Console → 项目设置 → 服务账号 → 生成新的私钥 中下载 JSON，然后将整个 JSON 内容粘贴为单行
FIREBASE_SERVICE_ACCOUNT_JSON=
# 方式二：分别配置三个字段（与方式一二选一）
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── APNs 推送（iOS 原生推送）─────────────────────────────────────────────
# 在 Apple Developer → Certificates, Identifiers & Profiles → Keys → 创建 APNs key
# 下载 .p8 文件，将文件内容（含 BEGIN/END 行）粘贴到 APNS_KEY_P8
APNS_KEY_P8=
# 密钥 ID（10 位字母数字，.p8 文件名中的那段）
APNS_KEY_ID=
# Apple Developer Team ID（10 位字母数字，developer.apple.com → Membership）
APNS_TEAM_ID=
# 应用 Bundle ID（如 com.summitlink.app）
APNS_BUNDLE_ID=com.summitlink.app

# ── 向导/俱乐部上架费（Stripe，PAYMENTS_ENABLED=true 时生效）────────────
# 向导上架费（美元，默认 299）
GUIDE_LISTING_FEE_USD=299
# 俱乐部上架费（美元，默认 499）
CLUB_LISTING_FEE_USD=499

# ── AI 助手开关（需完成《生成式 AI 服务管理暂行办法》备案后开启，默认关闭）
ENABLE_ASSISTANT=false
# ── AI 助手 ────────────────────────────────────────────────
OPENAI_API_KEY=

# ── 备份配置 ───────────────────────────────────────────────
BACKUPS_DIR=/data/backups

# ── 日志级别 ───────────────────────────────────────────────
LOG_LEVEL=info
