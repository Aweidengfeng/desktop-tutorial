JWT_SECRET=summitlink_secret_change_this_in_production
PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ── 短信服务（阿里云）────────────────────────────────────────
# 切换到阿里云短信：将 SMS_PROVIDER 改为 aliyun，并填写以下 4 个变量
# 不设置（或设为 mock）时使用控制台打印模式，适合开发/内测
SMS_PROVIDER=mock
# 阿里云 AccessKey（在控制台 → 访问控制 → AccessKey 管理 中创建）
ALIYUN_SMS_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
# 短信签名（在短信服务控制台申请，如"SummitLink"）
ALIYUN_SMS_SIGN_NAME=SummitLink
# 短信模板 Code（在短信服务控制台创建，模板须含 ${code} 变量）
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxx

# ── 邮件服务（SMTP）─────────────────────────────────────────
# 切换到 SMTP 发送：将 EMAIL_PROVIDER 改为 smtp，并填写以下变量
# 支持：阿里云企业邮箱(smtp.qiye.aliyun.com)、QQ邮箱、163邮箱、SendGrid 等
EMAIL_PROVIDER=mock
EMAIL_HOST=smtp.qiye.aliyun.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=noreply@your-domain.com
EMAIL_PASS=your_smtp_password_or_auth_code
EMAIL_FROM=SummitLink <noreply@your-domain.com>

# 微信登录（接入时填写真实值）
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# Apple 登录（接入时填写真实值）
APPLE_CLIENT_ID=com.example.summitlink
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here

# 高德地图 Web JS API Key（在高德开放平台申请后填入）
AMAP_KEY=your_amap_key_here
# 高德 Web JS API 2.0 安全密钥（必须配置，否则地图无法加载）
AMAP_SECURITY_CODE=your_amap_security_code_here

# ── 数据持久化（Railway Volume 挂载）────────────────────────
# 将 Railway Volume 挂载到 /data，然后设置以下两个变量
DATABASE_PATH=/data/summitlink.db

# Prisma ORM 数据库连接
# 开发/测试（SQLite）：
DATABASE_URL="file:./dev.db"
# 生产（Railway PostgreSQL）：
# 1. 将 backend/prisma/schema.prisma 中的 provider 改为 "postgresql"
# 2. 运行 npx prisma generate && npx prisma db push
# DATABASE_URL="postgresql://user:pass@host:5432/alpinelink"
UPLOADS_DIR=/data/uploads

# ── CORS 白名单（生产环境必填，逗号分隔）────────────────────
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Seed 开关（首次部署设 true，之后改回 false）─────────────
SEED_ON_START=false

# ── AI 助手开关（需完成《生成式 AI 服务管理暂行办法》备案后开启，默认关闭）
ENABLE_ASSISTANT=false
# ── AI 助手 ────────────────────────────────────────────────
OPENAI_API_KEY=

# ── 备份配置 ───────────────────────────────────────────────
BACKUPS_DIR=/data/backups

# ── 日志级别 ───────────────────────────────────────────────
LOG_LEVEL=info
