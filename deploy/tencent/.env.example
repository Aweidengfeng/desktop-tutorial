# SummitLink CN 节点 — 环境变量模板
# 文件路径：deploy/tencent/.env.example
# 使用方法：cp .env.example .env，然后填写真实值

# ---- 基础配置 ----
DEPLOY_REGION=cn
NODE_ENV=production
PORT=8080

# ICP 备案期间设为 false，备案通过后改为 true 并重启容器
SSL_ENABLED=false
# 由 SSL_ENABLED 自动控制，通常无需手动修改
COMPOSE_PROFILES=${SSL_ENABLED:-false}

# ---- 数据库（PostgreSQL，本地 Docker 容器）----
DATABASE_URL=postgresql://summitlink:CHANGEME@postgres:5432/summitlink
# 如有只读副本，可单独配置
# DATABASE_URL_CN=postgresql://summitlink:CHANGEME@postgres:5432/summitlink

# PostgreSQL 容器密码（与 DATABASE_URL 一致）
POSTGRES_PASSWORD=CHANGEME

# ---- 认证 & 加密 ----
JWT_SECRET=CHANGEME_64chars_random_string_here_use_openssl_rand_hex_32
PII_ENCRYPTION_KEY=CHANGEME_32chars_aes256_key_here
ADMIN_PASSWORD=CHANGEME_strong_admin_password

# ---- 支付（境内节点默认关闭 Stripe，使用微信/支付宝）----
PAYMENTS_ENABLED=false
STRIPE_DISABLED=true
PAYMENT_PROVIDER=wechat,alipay

# 微信支付（取得商户号后填入）
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=

# 支付宝（取得商户号后填入）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ---- 地图（境内使用高德）----
MAP_PROVIDER=amap
AMAP_KEY=

# ---- 腾讯云 COS 存储（图片 CDN）----
STORAGE_PROVIDER=cos
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=summitlink-cn-1300000000
TENCENT_COS_REGION=ap-shanghai
# CDN 加速域名（可选，COS 默认域名也可用）
COS_CDN_DOMAIN=

# ---- 监控 ----
SENTRY_DSN=

# ---- ICP 备案号（备案完成后填入）----
ICP_NUMBER=（备案中）
ICP_POLICE_NUMBER=（备案中）
