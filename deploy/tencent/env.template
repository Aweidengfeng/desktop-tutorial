# 腾讯云手动部署环境变量模板
# 用法：cp deploy/tencent/env.template .env

# =========================
# 必填（部署前必须填写）
# =========================
NODE_ENV=production
PORT=8080

# 数据库（建议使用腾讯云 PostgreSQL）
DATABASE_URL=postgresql://user:password@host:5432/desktop_tutorial
# docker-compose.cn.yml 会优先读取 DATABASE_URL_CN
DATABASE_URL_CN=postgresql://user:password@host:5432/desktop_tutorial

# 认证与管理后台
JWT_SECRET=replace_with_a_strong_random_secret
ADMIN_PASSWORD=replace_with_admin_password

# =========================
# 选填（按需填写）
# =========================
DATABASE_URL_US=
UPLOADS_DIR=/app/uploads

# 腾讯云 COS（如不使用 COS，可留空）
STORAGE_PROVIDER=local
COS_BUCKET=
COS_REGION=ap-shanghai
COS_SECRET_ID=
COS_SECRET_KEY=
COS_CDN_DOMAIN=
TENCENT_CLOUD_APPID=
TENCENT_CLOUD_REGION=ap-shanghai

# 支付（默认关闭 Stripe）
PAYMENT_PROVIDER=wechat
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY_V3=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 备案信息（可选）
ICP_NUMBER=
ICP_POLICE_NUMBER=
