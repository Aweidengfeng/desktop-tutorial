{
  "appId": "com.summitlink.app",
  "appName": "SummitLink",
  "webDir": "www",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  },
  "server": {
    "allowNavigation": ["*.summitlink.app"],
    "allowMixedContent": false
  }
}