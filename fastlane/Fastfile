# frozen_string_literal: true

# SummitLink – Fastlane Automation
#
# Available lanes:
#   fastlane beta_ios       – Build & upload to TestFlight
#   fastlane beta_android   – Build & upload to Google Play Internal Testing
#   fastlane beta           – Both iOS + Android
#   fastlane release_ios    – Build & upload to App Store (manual review required)
#
# Required environment variables / secrets (set in CI or ~/.env):
#   APPLE_API_KEY_ID        – App Store Connect API Key ID
#   APPLE_API_ISSUER_ID     – App Store Connect API Issuer ID
#   APPLE_API_KEY_CONTENT   – Base64-encoded .p8 key file content
#   GOOGLE_PLAY_JSON_KEY    – Path to Google Play service account JSON key file

default_platform(:ios)

# ── Shared helpers ──────────────────────────────────────────────────────────

def app_store_connect_api_key_config
  {
    key_id: ENV["APPLE_API_KEY_ID"],
    issuer_id: ENV["APPLE_API_ISSUER_ID"],
    key_content: ENV["APPLE_API_KEY_CONTENT"],
    is_key_content_base64: true,
    in_house: false
  }
end

# ── iOS lanes ───────────────────────────────────────────────────────────────

platform :ios do
  desc "Build and upload a new beta build to TestFlight"
  lane :beta_ios do
    api_key = app_store_connect_api_key(app_store_connect_api_key_config)

    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "build/ios",
      output_name: "SummitLink.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: File.exist?("fastlane/metadata/en-US/release_notes.txt") ?
                   File.read("fastlane/metadata/en-US/release_notes.txt") : "Beta build"
    )
  end

  desc "Upload metadata and screenshots to App Store (no submit)"
  lane :deliver_metadata do
    api_key = app_store_connect_api_key(app_store_connect_api_key_config)

    deliver(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true
    )
  end

  desc "Build and submit to App Store for review (use with care)"
  lane :release_ios do
    api_key = app_store_connect_api_key(app_store_connect_api_key_config)

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "build/ios",
      output_name: "SummitLink.ipa"
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      force: true
    )
  end
end

# ── Android lanes ────────────────────────────────────────────────────────────

platform :android do
  desc "Build and upload a new beta AAB to Google Play Internal Testing"
  lane :beta_android do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "android.injected.signing.store.file" => ENV["ANDROID_KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias" => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASSWORD"]
      }
    )

    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      release_status: "draft",
      version_name: lane_context[SharedValues::GRADLE_VERSION_NAME]
    )
  end
end

# ── Cross-platform lanes ─────────────────────────────────────────────────────

desc "Build and upload beta to TestFlight (iOS) AND Google Play Internal (Android)"
lane :beta do
  UI.message("🚀 Starting iOS beta build...")
  Fastlane::LaneManager.cruise_lane(:ios, :beta_ios)

  UI.message("🚀 Starting Android beta build...")
  Fastlane::LaneManager.cruise_lane(:android, :beta_android)

  UI.success("✅ Beta builds uploaded! iOS: TestFlight, Android: Google Play Internal")
end
