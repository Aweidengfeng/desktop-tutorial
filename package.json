{
  "name": "desktop-tutorial",
  "version": "1.0.0",
  "scripts": {
    "prisma:generate": "DATABASE_URL=\"file:/tmp/dev.db\" prisma generate --schema=backend/prisma/schema.prisma",
    "build": "cd backend && npm install && cd .. && npm run prisma:generate",
    "start": "node backend/app.js",
    "test:api": "node api_test.js",
    "test:api:unit": "npx jest --forceExit --no-coverage --runInBand",
    "test:api:legacy": "node tests/api.test.js",
    "test:e2e": "playwright test",
    "audit:clickables": "node scripts/clickable-audit.js",
    "test": "node run_all_tests.js",
    "smoke": "node scripts/smoke.js",
    "db:seed": "node backend/db/seed.js",
    "db:seed:dev": "NODE_ENV=development node backend/db/seed.js",
    "build:vite": "vite build",
    "preview": "vite preview",
    "test:load": "node backend/scripts/load-test.js",
    "generate:icons": "npx @capacitor/assets generate --ios --android",
    "generate:icons:ios": "npx @capacitor/assets generate --ios",
    "generate:icons:android": "npx @capacitor/assets generate --android",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "build:android": "npx cap sync android && cd android && ./gradlew bundleRelease",
    "build:ios": "npx cap sync ios && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Release -archivePath ios/App/App.xcarchive archive",
    "icons": "node scripts/generate-icons.js",
    "icons:from-svg": "node scripts/convert-svg-to-png.js && node scripts/generate-icons.js",
    "test:project": "npm run test:api && npm run test:e2e",
    "install:browsers": "npx playwright install chromium",
    "test:frontend": "node frontend_test.js",
    "test:db": "node db_test.js",
    "build:admin": "vite build --config vite.admin.config.js",
    "dev:admin": "vite --config vite.admin.config.js --port 3001"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@prisma/client": "^6.6.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "prisma": "^6.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "stripe": "^14.25.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jest": "^30.3.0",
    "mongodb": "^6.16.0",
    "mysql2": "^3.14.1",
    "pg": "^8.15.6",
    "playwright": "^1.59.1",
    "sharp": "^0.33.0",
    "supertest": "^7.2.2",
    "terser": "^5.30.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "wait-on": "^8.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/helpers/prismaGlobalSetup.js",
    "testMatch": [
      "**/tests/api-new-features.test.js",
      "**/tests/api-commerce.test.js",
      "**/tests/api-2026-features.test.js",
      "**/tests/api-offline-expedition.test.js",
      "**/tests/api-routes-teams.test.js",
      "**/tests/api-coverage.test.js",
      "**/tests/sos.test.js",
      "**/backend/tests/fix-duplicate-order-no.test.js",
      "**/backend/tests/payment-degraded.test.js",
      "**/backend/tests/payment-cn-framework.test.js",
      "**/backend/tests/security.test.js",
      "**/backend/tests/ownershipGuard.test.js",
      "**/backend/tests/sentry-pii.test.js",
      "**/backend/tests/concurrency.test.js",
      "**/backend/tests/jwt.test.js",
      "**/backend/tests/performance.test.js",
      "**/backend/tests/weak-network.test.js",
      "**/backend/tests/commission.test.js",
      "**/backend/tests/region.test.js",
      "**/backend/tests/storage.test.js",
      "**/backend/tests/mailer.test.js",
      "**/backend/tests/sms-sender.test.js",
      "**/backend/tests/admin-missing-apis.test.js",
      "**/tests/unit/ownershipGuard.test.js",
      "**/backend/tests/posts-resilience.test.js",
      "**/backend/tests/teams-resilience.test.js",
      "**/tests/api-feedback.test.js",
      "**/backend/tests/admin-v2-page.test.js"
    ],
    "testTimeout": 15000
  }
}
