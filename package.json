{
  "name": "desktop-tutorial",
  "version": "1.0.0",
  "scripts": {
    "build": "cd backend && npm install",
    "start": "node backend/db/seed.js && node backend/app.js",
    "test:api": "node tests/api.test.js && npx jest tests/api-new-features.test.js --forceExit --no-coverage",
    "test:api:unit": "npx jest tests/api-new-features.test.js --forceExit --no-coverage",
    "test:api:legacy": "node tests/api.test.js",
    "test:e2e": "playwright test",
    "test": "npm run test:api && npm run test:e2e",
    "smoke": "node scripts/smoke.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/api-new-features.test.js",
      "**/tests/api-commerce.test.js"
    ],
    "testTimeout": 15000
  }
}
