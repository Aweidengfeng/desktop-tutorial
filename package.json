{
  "name": "desktop-tutorial",
  "version": "1.0.0",
  "scripts": {
    "prisma:generate": "DATABASE_URL=\"file:/tmp/dev.db\" prisma generate --schema=backend/prisma/schema.prisma",
    "build": "npm run prisma:generate && cd backend && npm install",
    "start": "node backend/db/seed.js && node backend/app.js",
    "test:api": "node tests/api.test.js && npx jest --forceExit --no-coverage --runInBand",
    "test:api:unit": "npx jest --forceExit --no-coverage --runInBand",
    "test:api:legacy": "node tests/api.test.js",
    "test:e2e": "playwright test",
    "test": "npm run test:api && npm run test:e2e",
    "smoke": "node scripts/smoke.js",
    "db:seed": "node backend/db/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "prisma": "^5.22.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "wait-on": "^8.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/helpers/prismaGlobalSetup.js",
    "testMatch": [
      "**/tests/api-new-features.test.js",
      "**/tests/api-commerce.test.js",
      "**/tests/api-2026-features.test.js",
      "**/tests/api-offline-expedition.test.js",
      "**/tests/api-routes-teams.test.js",
      "**/tests/api-coverage.test.js"
    ],
    "testTimeout": 15000
  }
}